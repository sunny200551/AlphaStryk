{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@alphastryk/db": ["packages/db"],
      "@alphastryk/common": ["packages/common/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
