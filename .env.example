# ==============================================================================
# ALPHASTRYK ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to `.env` (backend/db) and `.env.local` (frontend) as needed.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (Neon PostgreSQL)
# ------------------------------------------------------------------------------
# Database URL format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://username:password@neon-host.neon.tech/alphastryk_db?sslmode=require"
# Direct database URL for running migrations bypassing poolers if PGBouncer is used
DIRECT_DATABASE_URL="postgresql://username:password@neon-host-direct.neon.tech/alphastryk_db?sslmode=require"

# ------------------------------------------------------------------------------
# 2. RUNTIME ENVIRONMENT
# ------------------------------------------------------------------------------
NODE_ENV="development" # development, production, test
PORT=5000

# ------------------------------------------------------------------------------
# 3. AUTHENTICATION SECRETS & TOKENS
# ------------------------------------------------------------------------------
JWT_SECRET="your_super_secure_jwt_secret_token_here_at_least_32_characters"
JWT_EXPIRES_IN="7d"

# Google OAuth Credentials
GOOGLE_CLIENT_ID="your_google_client_id_from_gcp_console.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret_from_gcp_console"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/v1/auth/google/callback"

# ------------------------------------------------------------------------------
# 4. THIRD-PARTY API INTEGRATIONS
# ------------------------------------------------------------------------------
# Cloudinary (Media upload and transformation engine)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Razorpay Payment Gateway API
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_signature_secret"

# PhonePe Payment Gateway API
PHONEPE_MERCHANT_ID="MERCHANTIDUAT"
PHONEPE_SALT_KEY="your_phonepe_api_salt_key"
PHONEPE_SALT_INDEX="1" # Default salt index
PHONEPE_ENV="UAT" # UAT (testing) or PROD (production)

# ------------------------------------------------------------------------------
# 5. FRONTEND / NEXT.JS CONFIGURATION (apps/web)
# ------------------------------------------------------------------------------
# Server-side environment variables in Next.js
NEXTAUTH_SECRET="your_nextauth_jwt_secret_different_from_backend"
NEXTAUTH_URL="http://localhost:3000"

# Public environment variables (prefixed with NEXT_PUBLIC_ to expose to browser)
NEXT_PUBLIC_API_URL="http://localhost:5000/api/v1"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_key_id"
